{
  "name": "vanta-base-admin",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@11.5.3",
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:generate": "pnpm --filter @vanta-base-admin/db db:generate",
    "db:migrate": "pnpm --filter @vanta-base-admin/db db:migrate",
    "db:seed": "pnpm --filter @vanta-base-admin/db db:seed",
    "db:push": "pnpm --filter @vanta-base-admin/db db:push",
    "db:studio": "pnpm --filter @vanta-base-admin/db db:studio",
    "test": "pnpm --filter @vanta-base-admin/api test"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "turbo": "^2.9.18",
    "typescript": "^5.6.0"
  }
}
