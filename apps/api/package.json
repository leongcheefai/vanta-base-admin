{
  "name": "@vanta-base-admin/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsup src/main.ts --format cjs --out-dir dist --no-splitting",
    "start": "node dist/main.js",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1044.0",
    "@aws-sdk/s3-request-presigner": "^3.1044.0",
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-express": "^10.4.0",
    "@octokit/rest": "^22.0.1",
    "@vanta-base-admin/auth": "workspace:*",
    "@vanta-base-admin/db": "workspace:*",
    "@vanta-base-admin/emails": "workspace:*",
    "@vanta-base-admin/env": "workspace:*",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.45.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.0",
    "stripe": "^22.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.4.0",
    "@types/express": "^5.0.0",
    "@types/supertest": "^6.0.0",
    "@types/node": "^22.0.0",
    "@vanta-base-admin/config": "workspace:*",
    "supertest": "^7.0.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
