# Copy to .env and fill in values

# Database (matches docker-compose.yml defaults)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vanta_base_admin

NODE_ENV=development

# Auth — generate with: openssl rand -base64 33
BETTER_AUTH_SECRET=change-me-at-least-32-characters-long!!
BETTER_AUTH_URL=http://localhost:3001

# Optional: Google OAuth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Resend — get from https://resend.com/api-keys
# Leave unset to skip email sends (app still boots)
# RESEND_API_KEY=re_...

# Stripe — get from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
# Get from: stripe listen --forward-to localhost:3001/billing/webhook
STRIPE_WEBHOOK_SECRET=whsec_...
# Optional: Pro plan price IDs (monthly and yearly)
# STRIPE_PRO_PRICE_ID_MONTHLY=price_...
# STRIPE_PRO_PRICE_ID_YEARLY=price_...

# Dashboard app URL (used for CORS and email links)
APP_URL=http://localhost:3000
# Marketing site URL (used for CORS on /billing/config and checkout)
# Required in production — set to the live marketing site origin (e.g. https://vanta-base-admin.dev)
WEB_URL=http://localhost:4321

# S3-compatible object storage for avatar uploads (AWS S3 or Cloudflare R2)
# Leave all unset to disable avatar uploads (app still boots)
# S3_REGION=auto
# S3_BUCKET=your-bucket-name
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com  # Cloudflare R2 only
# S3_PUBLIC_URL=https://pub-<hash>.r2.dev  # CDN base URL for served assets

# GitHub feedback → issue (optional)
# When set, each submitted feedback also opens a GitHub issue in the configured repo.
# PAT requires repo:issues write scope (fine-grained or classic).
# GITHUB_TOKEN=ghp_...
# GITHUB_OWNER=your-org-or-user
# GITHUB_REPO=your-repo
