---
import { getCollection } from "astro:content";
import { Badge } from "@vanta-base-admin/ui";
import BaseLayout from "../../layouts/BaseLayout.astro";

const entries = (await getCollection("releases")).sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime(),
);
---

<BaseLayout
  title="Releases — Vanta Base Admin"
  description="What's new in Vanta Base Admin. Release notes, improvements, and changelog."
  ogSlug="releases"
>
  <div class="mx-auto max-w-3xl px-6 py-24 sm:py-32">
    <h1 class="text-4xl font-bold tracking-tight">Releases</h1>
    <p class="mt-4 text-lg text-muted-foreground">
      What's new in Vanta Base Admin.
    </p>

    {
      entries.length === 0 ? (
        <p class="mt-12 text-muted-foreground">No releases yet.</p>
      ) : (
        <div class="mt-12 space-y-0">
          {entries.map((entry) => (
            <a
              href={`/releases/${entry.id}`}
              class="group flex items-start gap-6 border-b border-border py-8 transition-colors first:border-t hover:bg-muted/30 -mx-4 px-4 rounded-md"
            >
              <div class="min-w-[120px] pt-1">
                <time
                  datetime={entry.data.publishedAt.toISOString()}
                  class="text-sm text-muted-foreground"
                >
                  {entry.data.publishedAt.toLocaleDateString("en-US", {
                    year: "numeric",
                    month: "short",
                    day: "numeric",
                  })}
                </time>
              </div>
              <div class="flex-1">
                <div class="flex flex-wrap items-center gap-2">
                  <span class="font-semibold tracking-tight group-hover:text-primary transition-colors">
                    {entry.data.name}
                  </span>
                  <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-muted-foreground">
                    {entry.data.tag}
                  </code>
                  {entry.data.prerelease && (
                    <Badge variant="secondary" className="text-xs">
                      Pre-release
                    </Badge>
                  )}
                </div>
              </div>
              <span class="hidden text-muted-foreground transition-colors group-hover:text-foreground md:block">
                →
              </span>
            </a>
          ))}
        </div>
      )
    }
  </div>
</BaseLayout>
