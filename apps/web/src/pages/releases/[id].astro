---
import { getCollection, render } from "astro:content";
import { Badge } from "@praxor-kit/ui";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const entries = await getCollection("releases");
  return entries.map((entry) => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout
  title={`${entry.data.name} — Praxor Kit`}
  description={`Release notes for ${entry.data.tag}`}
  ogSlug="releases"
  ogType="article"
>
  <div class="mx-auto max-w-3xl px-6 py-24 sm:py-32">
    <a
      href="/releases"
      class="text-sm text-muted-foreground transition-colors hover:text-foreground"
    >
      ← Back to releases
    </a>
    <article class="mt-8">
      <header class="mb-10">
        <div class="flex flex-wrap items-center gap-2 text-sm text-muted-foreground">
          <time datetime={entry.data.publishedAt.toISOString()}>
            {
              entry.data.publishedAt.toLocaleDateString("en-US", {
                year: "numeric",
                month: "long",
                day: "numeric",
              })
            }
          </time>
          <span aria-hidden="true">·</span>
          <code class="rounded bg-muted px-1.5 py-0.5 font-mono text-xs">
            {entry.data.tag}
          </code>
          {
            entry.data.prerelease && (
              <Badge variant="secondary" className="text-xs">
                Pre-release
              </Badge>
            )
          }
        </div>
        <h1 class="mt-3 text-4xl font-bold tracking-tight">{entry.data.name}</h1>
        <a
          href={entry.data.url}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-3 inline-flex items-center gap-1 text-sm text-muted-foreground transition-colors hover:text-foreground"
        >
          View on GitHub ↗
        </a>
      </header>
      <div class="prose dark:prose-invert max-w-none">
        <Content />
      </div>
    </article>
  </div>
</BaseLayout>
