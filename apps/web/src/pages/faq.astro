---
import { FAQ } from "@praxor-kit/ui";
import BaseLayout from "../layouts/BaseLayout.astro";
import { requirePage } from "../lib/pages";
import { breadcrumbSchema, faqSchema } from "../lib/structured-data";

const page = requirePage("faq");
const site = Astro.site ?? new URL("https://kit.praxor.dev");

const faqItems = [
  {
    question: "TODO: First frequently asked question?",
    answer: "TODO: Answer to the first question.",
  },
  {
    question: "TODO: Second frequently asked question?",
    answer: "TODO: Answer to the second question.",
  },
  {
    question: "TODO: Third frequently asked question?",
    answer: "TODO: Answer to the third question.",
  },
  {
    question: "TODO: Fourth frequently asked question?",
    answer: "TODO: Answer to the fourth question.",
  },
  {
    question: "TODO: Fifth frequently asked question?",
    answer: "TODO: Answer to the fifth question.",
  },
  {
    question: "TODO: Sixth frequently asked question?",
    answer: "TODO: Answer to the sixth question.",
  },
  {
    question: "TODO: Seventh frequently asked question?",
    answer: "TODO: Answer to the seventh question.",
  },
  {
    question: "TODO: Eighth frequently asked question?",
    answer: "TODO: Answer to the eighth question.",
  },
];

const jsonLd = [
  faqSchema(faqItems),
  breadcrumbSchema([
    { name: "Home", url: site.origin },
    { name: "FAQ", url: new URL("/faq", site).href },
  ]),
];
---

<BaseLayout
  title={page.title}
  description={page.description}
  ogSlug={page.slug}
  jsonLd={jsonLd}
>
  <FAQ eyebrow="FAQ" headline="TODO: Frequently asked questions" items={faqItems} />
</BaseLayout>
