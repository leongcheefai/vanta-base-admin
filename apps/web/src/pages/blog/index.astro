---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout
  title="Blog — Praxor Kit"
  description="Insights, updates, and tutorials from the Praxor Kit team."
  ogSlug="blog"
>
  <div class="mx-auto max-w-3xl px-6 py-24 sm:py-32">
    <h1 class="text-4xl font-bold tracking-tight">Blog</h1>
    <p class="mt-4 text-lg text-muted-foreground">
      TODO: Brief intro to your blog — what you write about and who it's for.
    </p>
    <div class="mt-12 space-y-10 divide-y divide-border">
      {
        posts.map((post) => (
          <article class="pt-10 first:pt-0">
            <time
              datetime={post.data.date.toISOString()}
              class="text-sm text-muted-foreground"
            >
              {post.data.date.toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              })}
            </time>
            <h2 class="mt-2 text-2xl font-bold tracking-tight">
              <a
                href={`/blog/${post.id}`}
                class="transition-colors hover:text-primary"
              >
                {post.data.title}
              </a>
            </h2>
            <p class="mt-2 text-muted-foreground">{post.data.description}</p>
            <a
              href={`/blog/${post.id}`}
              class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-primary hover:underline"
            >
              Read more →
            </a>
          </article>
        ))
      }
    </div>
  </div>
</BaseLayout>
