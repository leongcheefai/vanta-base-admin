---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout
  title={`${post.data.title} — Praxor Kit`}
  description={post.data.description}
  ogSlug={`blog-${post.id}`}
>
  <div class="mx-auto max-w-3xl px-6 py-24 sm:py-32">
    <a
      href="/blog"
      class="text-sm text-muted-foreground transition-colors hover:text-foreground"
    >
      ← Back to blog
    </a>
    <article class="mt-8">
      <header class="mb-10">
        <time
          datetime={post.data.date.toISOString()}
          class="text-sm text-muted-foreground"
        >
          {post.data.date.toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          })}
        </time>
        <h1 class="mt-2 text-4xl font-bold tracking-tight">{post.data.title}</h1>
        <p class="mt-3 text-lg text-muted-foreground">{post.data.description}</p>
        <p class="mt-4 text-sm text-muted-foreground">By {post.data.author}</p>
      </header>
      <div class="prose">
        <Content />
      </div>
    </article>
  </div>
</BaseLayout>
