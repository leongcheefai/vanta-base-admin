---
import { getCollection, render } from "astro:content";
import { Badge } from "@praxor-kit/ui";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { readingTime } from "../../lib/reading-time";
import { articleSchema } from "../../lib/structured-data";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, remarkPluginFrontmatter } = await render(post);
const site = Astro.site ?? new URL("https://kit.praxor.dev");
const canonicalURL = new URL(`/blog/${post.id}`, site).href;

// Use remark-estimated-reading-time if available, otherwise fall back to our util
const rt = remarkPluginFrontmatter?.readingTime ?? readingTime(post.body ?? "").text;

const jsonLd = articleSchema({
  title: post.data.title,
  description: post.data.description,
  date: post.data.date,
  author: post.data.author,
  image: post.data.image ? new URL(post.data.image, site).href : undefined,
  url: canonicalURL,
});
---

<BaseLayout
  title={`${post.data.title} — Praxor Kit`}
  description={post.data.description}
  ogSlug={`blog-${post.id}`}
  ogType="article"
  jsonLd={jsonLd}
>
  <div class="mx-auto max-w-3xl px-6 py-24 sm:py-32">
    <a
      href="/blog"
      class="text-sm text-muted-foreground transition-colors hover:text-foreground"
    >
      ← Back to blog
    </a>
    <article class="mt-8">
      {post.data.image && (
        <img
          src={post.data.image}
          alt={post.data.imageAlt ?? post.data.title}
          class="mb-8 aspect-video w-full rounded-xl object-cover"
        />
      )}
      <header class="mb-10">
        <div class="flex flex-wrap items-center gap-2 text-sm text-muted-foreground">
          <time datetime={post.data.date.toISOString()}>
            {post.data.date.toLocaleDateString("en-US", {
              year: "numeric",
              month: "long",
              day: "numeric",
            })}
          </time>
          <span aria-hidden="true">·</span>
          <span>{rt}</span>
          {post.data.tags.length > 0 && (
            <>
              <span aria-hidden="true">·</span>
              {post.data.tags.map((tag) => (
                <Badge key={tag} variant="secondary" className="text-xs">
                  {tag}
                </Badge>
              ))}
            </>
          )}
        </div>
        <h1 class="mt-3 text-4xl font-bold tracking-tight">{post.data.title}</h1>
        <p class="mt-3 text-lg text-muted-foreground">{post.data.description}</p>
        <p class="mt-4 text-sm text-muted-foreground">By {post.data.author}</p>
      </header>
      <div class="prose">
        <Content />
      </div>
    </article>
  </div>
</BaseLayout>
