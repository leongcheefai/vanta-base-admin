---

<BaseLayout
  title={page.title}
  description={page.description}
  ogSlug={page.slug}
>
  <Section spacing="tight">
    <Container size="prose">
      <SectionHeader
        as="h1"
        align="center"
        headline="TODO: Loved by teams who ship"
        lede="TODO: Supporting copy about your customers — who they are and what they've achieved."
      />
    </Container>
  </Section>

  <LogoCloud
    label="TODO: Trusted by teams at"
    logos={[
      { name: "Company A" },
      { name: "Company B" },
      { name: "Company C" },
      { name: "Company D" },
      { name: "Company E" },
    ]}
  />

  <Section>
    <Container>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {testimonials.map((t) => (
          <Testimonial quote={t.quote} author={t.author} role={t.role} />
        ))}
      </div>
    </Container>
  </Section>
</BaseLayout>
