---
const APP_URL = import.meta.env.PUBLIC_APP_URL ?? 'http://localhost:3000'
const navLinks = [
  { label: 'Features', href: '/#features' },
  { label: 'Pricing', href: '/pricing' },
  { label: 'Blog', href: '/blog' },
]
---

<header class="sticky top-0 z-50 border-b border-border/60 bg-background/80 backdrop-blur-sm">
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-6">
    <a href="/" class="text-lg font-bold tracking-tight">Praxor Kit</a>
    <nav class="hidden items-center gap-6 md:flex" aria-label="Main navigation">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="text-sm text-muted-foreground transition-colors hover:text-foreground"
        >
          {link.label}
        </a>
      ))}
    </nav>
    <div class="flex items-center gap-3">
      <a
        href={`${APP_URL}/login`}
        class="text-sm text-muted-foreground transition-colors hover:text-foreground"
      >
        Sign in
      </a>
      <a
        href={`${APP_URL}/signup`}
        class="inline-flex h-9 items-center justify-center rounded-md bg-primary px-4 text-sm font-medium text-primary-foreground transition-colors hover:bg-primary/90"
      >
        Get started
      </a>
    </div>
  </div>
</header>
