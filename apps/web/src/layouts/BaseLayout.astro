---
import "../styles/global.css";
import { Toaster } from "@vanta-base-admin/ui";
import Footer from "../components/Footer";
import Nav from "../components/Nav.astro";

interface Props {
  title: string;
  description: string;
  ogSlug?: string;
  ogType?: "website" | "article";
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const { title, description, ogSlug = "home", ogType = "website", jsonLd } = Astro.props;
const site = Astro.site ?? new URL("https://vanta-base-admin.dev");
const canonicalURL = new URL(Astro.url.pathname, site);
const ogImage = new URL(`/og/${ogSlug}.png`, site);
const jsonLdArray = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <!-- Theme: read localStorage before paint to avoid flash -->
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem("theme");
          var prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
          if (t === "dark" || (!t && prefersDark)) {
            document.documentElement.classList.add("dark");
          }
        } catch (_) {}
      })();
    </script>
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" type="application/rss+xml" title="Vanta Base Admin Blog" href="/rss.xml" />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Vanta Base Admin" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    {jsonLdArray.map((payload) => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(payload)} />
    ))}
  </head>
  <body>
    <Nav />
    <main>
      <slot />
    </main>
    <Footer client:visible />
    <Toaster client:load />
  </body>
</html>
