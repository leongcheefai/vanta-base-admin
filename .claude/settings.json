{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cmd=$(jq -r '.tool_input.command // empty'); case \"$cmd\" in \"git commit\"*|\"git push\"*) pnpm build;; esac",
            "timeout": 120,
            "statusMessage": "Running pnpm build before commit/push..."
          }
        ]
      }
    ]
  }
}
