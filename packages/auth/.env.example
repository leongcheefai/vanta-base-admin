# Better Auth configuration
# These vars are read via apps/api — set them in apps/api/.env

# generate with: openssl rand -base64 33
BETTER_AUTH_SECRET=change-me-at-least-32-characters-long!!

# URL where the API is running (auth routes mount at /api/auth/*)
BETTER_AUTH_URL=http://localhost:3001

# URL of the dashboard app (used for CORS trusted origins)
APP_URL=http://localhost:3000

# Optional: Google OAuth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
